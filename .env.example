# Telegram bot tokens
TELEGRAM_TOKEN=
TELEGRAM_TOKEN_PROD=

# Telegram channel/chat IDs
FREELANCE_CHAN_ID=
SUPPORT_CHAT_ID=

# Database path (relative to /workdir inside container)
DB_PATH=../jobs2.db

# Docker user mapping
CURRENT_UID=1000
CURRENT_GID=1000

# SSH tunnel: path to key directory on HOST
SSH_TUN_DIR=~/.ssh_tun

# SSH tunnel connection
SSH_PROXY_HOST=
SSH_PROXY_PORT=
SSH_PROXY_USER=
SSH_IDENTITY_FILE=/workdir/.ssh_tun/id_ed25519
SSH_KNOWN_HOSTS=/workdir/.ssh_tun/known_hosts
SSH_LOCAL_SOCKS_PORT=2080
